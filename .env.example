# FretBoard 환경변수 목록
# 이 파일을 .env로 복사한 뒤 실제 값을 채워서 사용하세요.
# 실제 .env 파일은 절대 git에 커밋하지 마세요.

# --- Database ---
DB_PASSWORD=your_database_password_here

# --- JWT ---
JWT_TOKEN_SECRET=your_jwt_token_secret_min_64_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars_here

# --- AWS S3 ---
AWS_ACCESS_KEY=your_aws_access_key_id_here
AWS_SECRET_KEY=your_aws_secret_access_key_here
